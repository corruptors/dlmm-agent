# ── Wallet ────────────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── Solana RPC ─────────────────────────────────────────────────────────────────
RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Option A: OpenRouter (default)
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# Option B: LM Studio (local) — uncomment these and comment out OPENROUTER_API_KEY
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=your-model-name-from-lmstudio

# ── API Keys ───────────────────────────────────────────────────────────────────
HELIUS_API_KEY=your_helius_api_key_here
LPAGENT_API_KEY=your_lpagent_api_key_here

# ── Telegram Notifications (optional) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USER_IDS=

# ── Discord Notifications (optional) ──────────────────────────────────────────
# Get from: Discord Server → Settings → Integrations → Webhooks → New Webhook
# Receives filtered events: deploy, close, PnL alerts, out-of-range (with embeds)
DISCORD_WEBHOOK_URL=

# ── Discord Signal Listener (optional — for screening signals) ────────────────
# DISCORD_USER_TOKEN=your_discord_user_token
# DISCORD_GUILD_ID=your_guild_id
# DISCORD_CHANNEL_IDS=channel_id_1,channel_id_2

# ── Jupiter Swap API (optional — overrides default) ───────────────────────────
JUPITER_API_KEY=

# ── Dangerous admin actions (disabled by default) ─────────────────────────────
ALLOW_SELF_UPDATE=false

# ── Misc ───────────────────────────────────────────────────────────────────────
DRY_RUN=false
LOG_LEVEL=info
